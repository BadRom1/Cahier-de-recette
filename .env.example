# Copy to .env for local development (values below are safe defaults, not secrets).

# HTTP
PORT=3000
HOST=0.0.0.0

# Recipes storage (a directory of .cook files; on Railway: /data/recipes on the volume)
RECIPES_DIR=./data/recipes
# Sample recipes copied into RECIPES_DIR when it is empty (set to empty to disable)
SEED_RECIPES_DIR=./recipes

# Authentication: bearer token required for ALL write operations (reads are public).
# Writes are disabled when unset. Generate one with: openssl rand -hex 32
WRITE_TOKEN=

# Built web app served statically when the directory exists (dev uses the Vite proxy)
WEB_DIST_DIR=./apps/web/dist

LOG_LEVEL=info
