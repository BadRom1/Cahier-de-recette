# Copy to .env for local development (values below are safe defaults, not secrets).

# HTTP
PORT=3000
HOST=0.0.0.0

# Recipes storage (a directory of .cook files; on Railway: /data/recipes on the volume)
RECIPES_DIR=./data/recipes
# Sample recipes copied into RECIPES_DIR when it is empty (set to empty to disable)
SEED_RECIPES_DIR=./recipes

# Authentication: bearer token required for ALL write operations (reads are public).
# Writes are disabled when unset. Generate one with: openssl rand -hex 32
WRITE_TOKEN=

# Built web app served statically when the directory exists (dev uses the Vite proxy)
WEB_DIST_DIR=./apps/web/dist

# OAuth 2.1 for the MCP endpoint (needed to connect the server to Claude Web).
# When OAUTH_SECRET is set, /mcp becomes an OAuth-protected resource: clients
# must obtain an access token via the authorization flow. Leave OAUTH_SECRET
# empty to keep /mcp public (reads open, writes gated by WRITE_TOKEN).
#   - OAUTH_SECRET   : HMAC key signing tokens. Generate with: openssl rand -hex 32
#   - OAUTH_PASSWORD : password typed on the consent screen (falls back to WRITE_TOKEN)
#   - PUBLIC_URL     : public https URL, used in OAuth metadata (e.g. https://recettes.example.com)
OAUTH_SECRET=
OAUTH_PASSWORD=
PUBLIC_URL=

LOG_LEVEL=info
