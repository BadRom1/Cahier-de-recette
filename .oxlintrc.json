{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "suspicious": "error",
    "perf": "warn"
  },
  "plugins": ["typescript", "react", "unicorn", "oxc", "promise", "import"],
  "env": {
    "browser": true,
    "node": true,
    "es2024": true
  },
  "rules": {
    "no-console": "off",
    "import/no-cycle": "error",
    "react/react-in-jsx-scope": "off",
    "react/no-array-index-key": "off",
    "import/no-unassigned-import": ["error", { "allow": ["**/*.css"] }],
    "oxc/no-async-endpoint-handlers": "off",
    "eslint/no-underscore-dangle": [
      "error",
      { "allowAfterThis": true, "allow": ["_source", "_updatedAt"] }
    ]
  },
  "ignorePatterns": [
    "dist",
    "build",
    "coverage",
    "node_modules",
    "playwright-report",
    "test-results"
  ]
}
