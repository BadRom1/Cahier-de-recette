{
  "name": "@cahier/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "RECIPES_DIR=../../data/recipes SEED_RECIPES_DIR=../../recipes tsx watch src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "typecheck": "tsc --noEmit",
    "arch": "depcruise src --config .dependency-cruiser.cjs",
    "test": "vitest run",
    "test:unit": "vitest run --project unit",
    "test:integration": "vitest run --project integration"
  },
  "dependencies": {
    "@cooklang/cooklang": "^0.18.7",
    "@fastify/cors": "^11.3.0",
    "@fastify/static": "^10.1.2",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "fastify": "^5.10.0",
    "pino": "^10.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.20.1",
    "dependency-cruiser": "^18.1.0",
    "tsx": "^4.23.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10"
  }
}
